# Copy this file to `.env` and fill in the values.
# Never commit your real `.env` (it's already ignored by .gitignore).

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Reddit requires a descriptive user agent string.
# Example: linux:kebabtracker:v1.0.0 (by /u/YourMainAccount)
USER_AGENT=

# The subreddit to listen to (without "r/")
SUBREDDIT_NAME=KebabLog

# Local dev example (in production, point this at your mounted volume path)
DB_PATH=./data/kebab.db

# Sliding-window cooldown per user (hours) for non-backdated logs
# (Backdated logs bypass this cooldown.)
KEBAB_COOLDOWN_HOURS=4

# Polling interval for /r/<sub>/comments
POLL_INTERVAL_MS=15000

# Request timeout for Reddit HTTP calls
REQUEST_TIMEOUT_MS=10000

# debug | info | warn | error
LOG_LEVEL=info
